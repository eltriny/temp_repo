# ============================================================================
# Video Detection — 환경 변수 템플릿
# ----------------------------------------------------------------------------
# 이 파일을 `.env` 로 복사한 뒤 값을 채우세요. `.env` 는 git 에 커밋하지 않습니다.
# 런타임은 python-dotenv 를 통해 main() 진입 직후 1회 로드합니다.
# ============================================================================

# ----- Runtime profile -------------------------------------------------------
# dev | staging | prod   (Phase 3 에서 프로파일별 YAML 도입)
VIDEO_DETECTION_ENV=dev

# ----- PostgreSQL 연결 -------------------------------------------------------
# 방법 A: 개별 필드
VIDEO_DETECTION_DB_HOST=localhost
VIDEO_DETECTION_DB_PORT=5432
VIDEO_DETECTION_DB_NAME=video_detection
VIDEO_DETECTION_DB_USER=video_detect
VIDEO_DETECTION_DB_PASSWORD=change_me_please
VIDEO_DETECTION_DB_SCHEMA=public

# 방법 B: 전체 DSN (우선 적용됨)
# VIDEO_DETECTION_DB_DSN=postgresql://video_detect:change_me@localhost:5432/video_detection

# Pool 튜닝 (옵션)
# VIDEO_DETECTION_DB_POOL_MIN=2
# VIDEO_DETECTION_DB_POOL_MAX=10

# ----- 로깅 ------------------------------------------------------------------
VIDEO_DETECTION_LOG_LEVEL=INFO
# VIDEO_DETECTION_LOG_DIR=./logs
# VIDEO_DETECTION_LOG_JSON=0           # 1 이면 JSON 구조화 로그 (prod 권장)

# ----- 출력 / 디스크 가드 -----------------------------------------------------
# VIDEO_DETECTION_OUTPUT_DIR=./data/output
# VIDEO_DETECTION_MIN_FREE_DISK_MB=2048
# VIDEO_DETECTION_DISK_CHECK_ACTION=warn   # warn | skip | abort

# ----- OCR -------------------------------------------------------------------
# VIDEO_DETECTION_USE_GPU=0
# VIDEO_DETECTION_OCR_LANG=ch

# ----- 테스트 전용 -----------------------------------------------------------
# 외부 PostgreSQL 을 쓰는 통합 테스트용. tests/integration/ 에서만 사용.
# PG_DSN=postgresql://video_detect:change_me@localhost:5432/video_detection_test
# USE_EXTERNAL_PG=1
